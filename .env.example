# Required for AI chat
OPENROUTER_API_KEY=

# Optional OpenRouter overrides
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_HTTP_REFERER=https://frederick-aurelio-halim.vercel.app
OPENROUTER_APP_TITLE=Frederick Portfolio

# Chat storage (pick one provider)
CHAT_STORE_PROVIDER=redis

# Self-hosted Redis (VPS Docker / local dev with docker-compose.dev-db.yml)
REDIS_URL=redis://127.0.0.1:6379

# Upstash (Vercel serverless)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Message retention — sliding window, resets on each new message (default 6 hours)
CHAT_MESSAGE_TTL_SECONDS=21600
